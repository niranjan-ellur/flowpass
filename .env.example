# FlowPass environment variables.
# Copy this file to .env and fill in real values. NEVER commit .env.

# Environment: development | production
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8080

# Google services
# Get from https://aistudio.google.com (click "Get API key")
GEMINI_API_KEY=

# Maps Demo Key - get from Google Maps Platform console
MAPS_API_KEY=
